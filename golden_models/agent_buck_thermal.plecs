      Name          "Tj_Q1_prb"
      Show          on
      Position      [490, -20]
      Direction     right
      Flipped       off
      LabelPosition south
      Probe {
        Component     "Q1"
        Path          ""
        Signals       {"MOSFET junction temp"}
      }
    }
    Component {
      Type          Output
      Name          "Tj_Q1"
      Show          on
      Position      [550, -20]
      Direction     right
      Flipped       off
      LabelPosition south
      Parameter {
        Variable      "Index"
        Value         "1"
        Show          on
      }
      Parameter {
        Variable      "Width"
        Value         "-1"
        Show          off
      }
    }
    Component {
