      LabelPosition south
      Parameter {
        Variable      "Index"
        Value         "2"
        Show          on
      }
      Parameter {
        Variable      "Width"
        Value         "-1"
        Show          off
      }
    }
    Connection {
      Type          Wire
      SrcComponent  "VDCin"
      SrcTerminal   1
      Points        [60, 95]
      Branch {
        Points        [105, 95]
        DstComponent  "Q1"
        DstTerminal   1
      }
    }
    Connection {
      Type          Wire
      SrcComponent  "Q1"
      SrcTerminal   2
      Points        [155, 95]
      Branch {
        Points        [200, 95]
        DstComponent  "D1"
        DstTerminal   2
      }
      Branch {
        Points        [245, 95]
        DstComponent  "L1"
        DstTerminal   1
      }
    }
    Connection {
      Type          Wire
      SrcComponent  "L1"
      SrcTerminal   2
      Points        [295, 95]
      Branch {
        Points        [340, 95]
        DstComponent  "C1"
        DstTerminal   1
      }
      Branch {
        Points        [410, 95]
        DstComponent  "R1"
        DstTerminal   1
      }
    }
    Connection {
      Type          Wire
      SrcComponent  "VDCin"
      SrcTerminal   2
      Points        [60, 185]
      Branch {
        Points        [200, 185]
        DstComponent  "D1"
        DstTerminal   1
      }
      Branch {
        Points        [340, 185]
        DstComponent  "C1"
        DstTerminal   2
      }
      Branch {
        Points        [410, 185]
        DstComponent  "R1"
        DstTerminal   2
      }
    }
    Connection {
      Type          Signal
      SrcComponent  "PWM"
      SrcTerminal   1
      DstComponent  "Q1"
      DstTerminal   3
    }
    Connection {
      Type          HeatPipe
      SrcComponent  "HS_Q1"
