      DstTerminal   2
    }
    Connection {
      Type          HeatPipe
      SrcComponent  "Wm_Q1"
      SrcTerminal   1
      DstComponent  "Rth_Q1"
      DstTerminal   1
    }
    Connection {
      Type          HeatPipe
      SrcComponent  "Rth_Q1"
      SrcTerminal   2
      DstComponent  "Tamb_Q1"
      DstTerminal   1
    }
    Connection {
      Type          Signal
      SrcComponent  "Tj_Q1_prb"
