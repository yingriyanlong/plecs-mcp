      Position      [340, 140]
      Direction     down
      Flipped       on
      LabelPosition south
      Parameter {
        Variable      "C"
        Value         "Co"
        Show          off
      }
    }
    Component {
      Type          Resistor
      Name          "R1"
      Show          on
      Position      [410, 140]
      Direction     down
      Flipped       on
      LabelPosition south
      Parameter {
        Variable      "R"
        Value         "Ro"
        Show          off
      }
    }
    Component {
      Type          PulseGenerator
      Name          "PWM"
      Show          on
      Position      [100, 210]
      Direction     right
      Flipped       off
      LabelPosition south
      Parameter {
        Variable      "f"
        Value         "fsw"
        Show          off
      }
      Parameter {
        Variable      "DutyCycle"
        Value         "D"
        Show          off
      }
    }
    Component {
      Type          HeatSink
      Name          "HS_Q1"
      Show          on
      Position      [130, 95]
      Direction     up
      Flipped       off
      LabelPosition south
      Frame         [-22, -26; 22, 26]
      Parameter {
        Variable      "Cth"
        Value         "0"
        Show          off
      }
      Parameter {
        Variable      "T_init"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "Width"
        Value         "1"
        Show          off
      }
      Terminal {
        Type          HeatPort
        Position      [0, -46]
        Direction     up
      }
    }
    Component {
      Type          HeatFlowMeter
      Name          "Wm_Q1"
      Show          on
      Position      [550, 25]
      Direction     up
      Flipped       off
      LabelPosition south
